{
  "name": "basmatlibya",
  "private": true,
  "version": "0.1.0",
  "description": "BasmatLibya — Arabic-first digital footprint analyzer",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @basmat/web dev",
    "build": "pnpm --filter @basmat/shared build && pnpm --filter @basmat/web build",
    "test": "pnpm -r --no-bail run test",
    "typecheck": "pnpm -r --no-bail run typecheck",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "eslint": "^9.12.0",
    "@eslint/js": "^9.12.0",
    "typescript-eslint": "^8.8.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2"
  }
}
