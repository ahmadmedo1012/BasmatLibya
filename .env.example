# --- Required ---
# Neon PostgreSQL connection string (or local: postgres://basmat:basmat@localhost:5434/basmat)
DATABASE_URL=postgres://basmat:basmat@localhost:5434/basmat

# Public URL of the service (used for canonical share links and CORS origin)
PUBLIC_BASE_URL=http://localhost:5173

# Telegram bot token (from @BotFather). Required to verify Login Widget payloads.
TELEGRAM_BOT_TOKEN=

# Telegram bot username (without @). Required for the Login Widget.
# Injected into SPA HTML at serve-time in production. In dev, Vite reads
# VITE_TELEGRAM_BOT_USERNAME from apps/web/.env.local.
TELEGRAM_BOT_USERNAME=BasmatLibyabot

# Encryption key for AI model credentials at rest.
# 32 raw bytes, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MODEL_SECRET_KEY=

# --- Recommended ---
# NVIDIA NIM API key for AI enrichment. Without it, enrichment will skip AI calls.
NVIDIA_API_KEY=

# Cookie domain scope (e.g., ".onrender.com"). Leave empty for host-only in dev.
COOKIE_DOMAIN=

# Numeric Telegram user ID of the platform owner (NOT the phone number).
# Run scripts/bootstrap-owner.ts to resolve the +218 091 008 9975 account to a numeric id.
OWNER_TELEGRAM_ID=

# Previous encryption key during rotation. Decrypt-only fallback for existing records.
MODEL_SECRET_KEY_PREVIOUS=

# --- Optional ---
# NumVerify API key for phone carrier + line type lookup (https://numverify.com — 100 req/month free).
NUMVERIFY_API_KEY=

# SerpAPI key for structured Google search across all identifier types (https://serpapi.com — 100 req/month free).
SERPAPI_KEY=

# REST URL of the PhoneInfoga container (docker compose up -d phoneinfoga).
# Leave empty to disable the provider gracefully.
PHONEINFOGA_URL=http://localhost:5050

# --- Server defaults (can be overridden) ---
NODE_ENV=development
PORT=3001
SOURCE_PROVIDERS=live
RATE_LIMIT_WINDOW_MINUTES=10
RATE_LIMIT_MAX_PER_WINDOW=5
RETENTION_DAYS=30

# --- Enrichment (feature 001 — legacy, feature 002 supersedes) ---
ENRICHMENT_ENABLED=false
ENRICHMENT_FAST=true
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_RESEARCHER=nvidia/nemotron-3-super-120b-a12b
NVIDIA_MODEL_FAST=nvidia/nemotron-3-super-120b-a12b
NVIDIA_MODEL_ANALYZER=meta/llama-3.3-70b-instruct
NVIDIA_MODEL_REASONER=nvidia/llama-3.3-nemotron-super-49b-v1.5
NVIDIA_MODEL_WRITER=mistralai/mistral-medium-3.5-128b
NVIDIA_TIMEOUT_MS=90000
